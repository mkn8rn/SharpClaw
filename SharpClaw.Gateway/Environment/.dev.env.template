{
  // SharpClaw Gateway development overrides.
  //
  // Development mode enables the built-in REST endpoint groups so local
  // integration tests and manual API checks do not need to edit the base
  // gateway .env first.

  "InternalApi": {
    "BaseUrl": "http://127.0.0.1:48923",
    "TimeoutSeconds": "300"
  },

  "Logging": {
    // Development defaults emit debug-level gateway logs. Raw Serilog file
    // output goes to serilog.txt; session ILogger output goes to log.txt,
    // debug.txt, and exceptions.txt in the instance log folder.
    "Serilog": {
      "Enabled": "true",
      "ConsoleEnabled": "true",
      "FileEnabled": "true",
      "RequestLoggingEnabled": "true",
      "MinimumLevel": "Debug",
      "MicrosoftMinimumLevel": "Information",
      "AspNetCoreMinimumLevel": "Information",
      "EntityFrameworkCoreMinimumLevel": "Information",
      "UnoMinimumLevel": "Information"
    }
  },

  "Gateway": {
    "RequestQueue": {
      "Enabled": "true",
      "MaxConcurrency": "1",
      "TimeoutSeconds": "30",
      "MaxRetries": "2",
      "RetryDelayMs": "500",
      "MaxQueueSize": "500"
    },

    "Endpoints": {
      "Enabled": "true",
      "Auth": "true",
      "Agents": "true",
      "Channels": "true",
      "ChannelContexts": "true",
      "Chat": "true",
      "ChatStream": "true",
      "Threads": "true",
      "ThreadChat": "true",
      "ThreadWatch": "true",
      "Jobs": "true",
      "Models": "true",
      "LocalModels": "true",
      "Providers": "true",
      "Roles": "true",
      "Users": "true",
      "Cost": "true",
      "Tasks": "true",
      "TaskStreaming": "true",
      "ToolAwarenessSets": "true",
      "Resources": "true"
    },

    "Modules": {
      "Modules": {},
      "Groups": {},
      "HotReloadEnabled": "false",
      "DrainTimeoutSeconds": "30"
    }
  }
}
