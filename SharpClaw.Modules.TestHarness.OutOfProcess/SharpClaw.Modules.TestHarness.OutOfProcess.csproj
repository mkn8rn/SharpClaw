<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <DefineConstants>$(DefineConstants);TEST_HARNESS_OUT_OF_PROCESS</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\SharpClaw.Modules.TestHarness.Shared\*.cs"
             Link="%(Filename)%(Extension)" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="SharpClaw.Contracts" />
    <PackageReference Include="SharpClaw.Providers.Common" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="module.json"
             Link="modules\sharpclaw_test_harness_out_of_process\module.json"
             CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
