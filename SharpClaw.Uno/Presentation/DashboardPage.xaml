<Page x:Class="SharpClaw.Presentation.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:SharpClaw.Presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      NavigationCacheMode="Required"
      Background="Black">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="24,20,24,0" Spacing="4">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <TextBlock Text="SharpClaw"
                   Style="{StaticResource TerminalText}"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#00FF00"
                   VerticalAlignment="Center" />
        <TextBlock Text="alpha test"
                   Style="{StaticResource TerminalText}"
                   FontSize="12"
                   Foreground="#666666"
                   VerticalAlignment="Center" />
      </StackPanel>
      <TextBlock Text="> Dashboard"
                 Style="{StaticResource TerminalText}"
                 FontSize="13"
                 Foreground="#808080"
                 Margin="0,4,0,0" />
      <Border Height="1" Background="#1A1A1A" Margin="0,12,0,0" />
    </StackPanel>

    <!-- Menu -->
    <ScrollViewer Grid.Row="1" Margin="24,12,24,0">
      <StackPanel x:Name="MenuPanel" Spacing="2">

        <local:TerminalSectionHeader Title="Models" Margin="0,8,0,6" />
        <local:TerminalMenuButton TagKey="Providers"     Label="Providers"      Description="API provider connections"     MenuClick="OnMenuItemClick" MenuPointerEntered="OnMenuItemHover" MenuPointerExited="OnMenuItemLeave" />
        <local:TerminalMenuButton TagKey="Models"        Label="Models"         Description="LLM model registry"          MenuClick="OnMenuItemClick" MenuPointerEntered="OnMenuItemHover" MenuPointerExited="OnMenuItemLeave" />
        <local:TerminalMenuButton TagKey="LocalModels"   Label="Local Models"   Description="on-device inference"          MenuClick="OnMenuItemClick" MenuPointerEntered="OnMenuItemHover" MenuPointerExited="OnMenuItemLeave" />

        <local:TerminalSectionHeader Title="Agents" Margin="0,16,0,6" />
        <local:TerminalMenuButton TagKey="Agents"        Label="Agents"         Description="agent profiles &amp; configuration" MenuClick="OnMenuItemClick" MenuPointerEntered="OnMenuItemHover" MenuPointerExited="OnMenuItemLeave" />
        <local:TerminalMenuButton TagKey="Roles"         Label="Roles"          Description="permission sets &amp; clearance"    MenuClick="OnMenuItemClick" MenuPointerEntered="OnMenuItemHover" MenuPointerExited="OnMenuItemLeave" />
        <local:TerminalMenuButton TagKey="Jobs"          Label="Jobs"           Description="async agent tasks"            MenuClick="OnMenuItemClick" MenuPointerEntered="OnMenuItemHover" MenuPointerExited="OnMenuItemLeave" />

        <local:TerminalSectionHeader Title="Chat" Margin="0,16,0,6" />
        <local:TerminalMenuButton TagKey="Channels"      Label="Channels"       Description="chat channels &amp; threads"       MenuClick="OnMenuItemClick" MenuPointerEntered="OnMenuItemHover" MenuPointerExited="OnMenuItemLeave" />
        <local:TerminalMenuButton TagKey="Contexts"      Label="Contexts"       Description="channel context presets"      MenuClick="OnMenuItemClick" MenuPointerEntered="OnMenuItemHover" MenuPointerExited="OnMenuItemLeave" />

        <local:TerminalSectionHeader Title="Resources" Margin="0,16,0,6" />
        <local:TerminalMenuButton TagKey="Resources"     Label="Resources"      Description="shells, containers, devices"  MenuClick="OnMenuItemClick" MenuPointerEntered="OnMenuItemHover" MenuPointerExited="OnMenuItemLeave" />
        <local:TerminalMenuButton TagKey="Editor"        Label="Editor Sessions" Description="IDE bridge connections"      MenuClick="OnMenuItemClick" MenuPointerEntered="OnMenuItemHover" MenuPointerExited="OnMenuItemLeave" />
        <local:TerminalMenuButton TagKey="Transcription" Label="Transcription"  Description="speech-to-text sessions"     MenuClick="OnMenuItemClick" MenuPointerEntered="OnMenuItemHover" MenuPointerExited="OnMenuItemLeave" />

        <local:TerminalSectionHeader Title="System" Margin="0,16,0,6" />
        <local:TerminalMenuButton TagKey="Auth"          Label="Auth &amp; Users"   Description="sessions &amp; tokens"             MenuClick="OnMenuItemClick" MenuPointerEntered="OnMenuItemHover" MenuPointerExited="OnMenuItemLeave" />

      </StackPanel>
    </ScrollViewer>

    <!-- Footer -->
    <StackPanel Grid.Row="2" Margin="24,8,24,16" Spacing="8">
      <Border Height="1" Background="#1A1A1A" />
      <StackPanel Orientation="Horizontal" Spacing="16">
        <Button Background="Transparent" BorderThickness="0" Padding="0"
                Click="OnBackClick">
          <TextBlock Text="> Back to Chat"
                     Style="{StaticResource TerminalText}"
                     FontSize="12"
                     Foreground="#808080" />
        </Button>
        <TextBlock x:Name="StatusBlock"
                   Style="{StaticResource TerminalText}"
                   FontSize="12"
                   Foreground="#808080"
                   VerticalAlignment="Center" />
      </StackPanel>
      <local:TerminalCursor x:Name="Cursor" />
    </StackPanel>
  </Grid>
</Page>
