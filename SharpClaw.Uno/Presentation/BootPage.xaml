<Page x:Class="SharpClaw.Presentation.BootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:SharpClaw.Presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      NavigationCacheMode="Required"
      IsTabStop="True"
      Background="Black">

  <Grid
        VerticalAlignment="Stretch">

    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="6"
                MinWidth="420">

      <!-- Title -->
      <TextBlock Text="SharpClaw"
                 Style="{StaticResource TerminalText}"
                 FontSize="28"
                 FontWeight="Bold"
                 Foreground="#00FF00"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,16" />

      <!-- Blinking cursor / command line -->
      <local:TerminalCursor x:Name="Cursor"
                            Margin="0,0,0,4" />

      <!-- Dots animation (during connecting, after typewriter) -->
      <TextBlock x:Name="DotsBlock"
                 Style="{StaticResource TerminalText}"
                 FontSize="14"
                 Foreground="#808080"
                 Visibility="Collapsed"
                 Margin="0,4,0,0" />

      <!-- Status / result line (appears after command completes) -->
      <StackPanel x:Name="StatusPanel"
                  Orientation="Horizontal"
                  Spacing="8"
                  Visibility="Collapsed">
        <TextBlock x:Name="StatusIconBlock"
                   Style="{StaticResource TerminalText}"
                   FontSize="16"
                   Foreground="#808080"
                   VerticalAlignment="Center" />
        <TextBlock x:Name="StatusTextBlock"
                   Style="{StaticResource TerminalText}"
                   FontSize="16"
                   Foreground="#CCCCCC"
                   VerticalAlignment="Center" />
      </StackPanel>

      <!-- Retry prompt -->
      <TextBlock x:Name="RetryPromptBlock"
                 Text="Press Enter to retry or Escape to exit."
                 Style="{StaticResource TerminalText}"
                 FontSize="14"
                 Foreground="#808080"
                 Visibility="Collapsed"
                 Margin="0,20,0,0" />

      <!-- URL override -->
      <StackPanel x:Name="UrlPanel"
                  Visibility="Collapsed"
                  Margin="0,12,0,0"
                  Spacing="4">
        <TextBlock Text="Service URL:"
                   Style="{StaticResource TerminalText}"
                   FontSize="12"
                   Foreground="#808080" />
        <TextBox x:Name="UrlBox"
                 Style="{StaticResource TerminalInput}"
                 FontSize="13"
                 IsTabStop="True" />
      </StackPanel>
    </StackPanel>
  </Grid>
</Page>
