<Page x:Class="SharpClaw.Presentation.BootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      NavigationCacheMode="Required"
      Background="Black">

  <Page.Resources>
    <Style x:Key="TerminalText" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="Consolas, Courier New, monospace" />
    </Style>
  </Page.Resources>

  <Grid HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">

    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="6"
                MinWidth="420">

      <!-- Title -->
      <TextBlock Text="SharpClaw"
                 Style="{StaticResource TerminalText}"
                 FontSize="28"
                 FontWeight="Bold"
                 Foreground="#00FF00"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,16" />

      <!-- Status line -->
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock x:Name="StatusIconBlock"
                   Text="{Binding StatusIcon}"
                   Style="{StaticResource TerminalText}"
                   FontSize="16"
                   Foreground="#808080"
                   VerticalAlignment="Center" />
        <TextBlock x:Name="StatusTextBlock"
                   Text="{Binding StatusText}"
                   Style="{StaticResource TerminalText}"
                   FontSize="16"
                   Foreground="#CCCCCC"
                   VerticalAlignment="Center" />
      </StackPanel>

      <!-- Spinner -->
      <ProgressRing x:Name="SpinnerRing"
                    IsActive="False"
                    Height="24" Width="24"
                    HorizontalAlignment="Left"
                    Margin="24,4,0,0"
                    Foreground="#00FF00"
                    Visibility="Collapsed" />

      <!-- Retry prompt -->
      <TextBlock x:Name="RetryPromptBlock"
                 Text="Press Enter to retry or Escape to exit."
                 Style="{StaticResource TerminalText}"
                 FontSize="14"
                 Foreground="#808080"
                 Visibility="Collapsed"
                 Margin="0,20,0,0" />

      <!-- Blinking cursor -->
      <TextBlock x:Name="CursorBlock"
                 Text="_"
                 Style="{StaticResource TerminalText}"
                 FontSize="16"
                 Foreground="#00FF00"
                 Visibility="Collapsed"
                 Margin="0,4,0,0" />
    </StackPanel>
  </Grid>
</Page>
