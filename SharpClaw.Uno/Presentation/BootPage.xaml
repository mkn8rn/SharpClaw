<Page x:Class="SharpClaw.Presentation.BootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:SharpClaw.Presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      NavigationCacheMode="Required"
      IsTabStop="True"
      Background="Black">

  <Grid
        VerticalAlignment="Stretch">

    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="6"
                MinWidth="420">

      <!-- Title -->
      <TextBlock Text="SharpClaw"
                 Style="{StaticResource TerminalText}"
                 FontSize="28"
                 FontWeight="Bold"
                 Foreground="#00FF00"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,16" />

      <!-- Blinking cursor / command line (echo step) -->
      <local:TerminalCursor x:Name="Cursor"
                            Margin="0,0,0,4" />

      <!-- Dots animation (during probing, after typewriter) -->
      <TextBlock x:Name="DotsBlock"
                 Style="{StaticResource TerminalText}"
                 FontSize="14"
                 Foreground="#808080"
                 Visibility="Collapsed"
                 Margin="0,4,0,0" />

      <!-- Echo result line (✓ / ✗ after echo probe) -->
      <StackPanel x:Name="EchoResultPanel"
                  Orientation="Horizontal"
                  Spacing="8"
                  Visibility="Collapsed">
        <TextBlock x:Name="EchoIconBlock"
                   Style="{StaticResource TerminalText}"
                   FontSize="16"
                   VerticalAlignment="Center" />
        <TextBlock x:Name="EchoTextBlock"
                   Style="{StaticResource TerminalText}"
                   FontSize="16"
                   VerticalAlignment="Center" />
      </StackPanel>

      <!-- Second cursor / command line (ping step) -->
      <local:TerminalCursor x:Name="PingCursor"
                            Margin="0,4,0,4"
                            Visibility="Collapsed" />

      <!-- Dots animation for ping step -->
      <TextBlock x:Name="PingDotsBlock"
                 Style="{StaticResource TerminalText}"
                 FontSize="14"
                 Foreground="#808080"
                 Visibility="Collapsed"
                 Margin="0,4,0,0" />

      <!-- Ping / final result line -->
      <StackPanel x:Name="StatusPanel"
                  Orientation="Horizontal"
                  Spacing="8"
                  Visibility="Collapsed">
        <TextBlock x:Name="StatusIconBlock"
                   Style="{StaticResource TerminalText}"
                   FontSize="16"
                   Foreground="#808080"
                   VerticalAlignment="Center" />
        <TextBlock x:Name="StatusTextBlock"
                   Style="{StaticResource TerminalText}"
                   FontSize="16"
                   Foreground="#CCCCCC"
                   VerticalAlignment="Center" />
      </StackPanel>

      <!-- Diagnostic log (step-by-step probe results) -->
      <StackPanel x:Name="DiagPanel"
                  Visibility="Collapsed"
                  Margin="0,16,0,0"
                  Spacing="2">
        <StackPanel Orientation="Horizontal"
                    Spacing="12"
                    Margin="0,0,0,4">
          <TextBlock Text="Diagnostics"
                     Style="{StaticResource TerminalText}"
                     FontSize="12"
                     Foreground="#808080"
                     VerticalAlignment="Center" />
          <Button x:Name="CopyLogsButton"
                  Click="OnCopyLogsClick"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="4,2"
                  MinWidth="0"
                  MinHeight="0"
                  VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <FontIcon Glyph="&#xE8C8;"
                        FontSize="12"
                        Foreground="#808080" />
              <TextBlock x:Name="CopyLogsLabel"
                         Text="Copy"
                         Style="{StaticResource TerminalText}"
                         FontSize="11"
                         Foreground="#808080" />
            </StackPanel>
          </Button>
        </StackPanel>
        <StackPanel x:Name="DiagLines" Spacing="2" />
        <!-- Backend process output (populated programmatically) -->
        <StackPanel x:Name="ProcessOutputPanel"
                    Visibility="Collapsed"
                    Margin="0,8,0,0"
                    Spacing="2">
          <TextBlock Text="Process Output"
                     Style="{StaticResource TerminalText}"
                     FontSize="12"
                     Foreground="#808080"
                     Margin="0,0,0,2" />
          <ScrollViewer MaxHeight="140"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <TextBlock x:Name="ProcessOutputBlock"
                       Style="{StaticResource TerminalText}"
                       FontSize="11"
                       Foreground="#999999"
                       TextWrapping="Wrap"
                       IsTextSelectionEnabled="True" />
          </ScrollViewer>
        </StackPanel>
      </StackPanel>

      <!-- Retry prompt -->
      <TextBlock x:Name="RetryPromptBlock"
                 Text="Press Enter to retry or Escape to exit."
                 Style="{StaticResource TerminalText}"
                 FontSize="14"
                 Foreground="#808080"
                 Visibility="Collapsed"
                 Margin="0,20,0,0" />

      <!-- URL override -->
      <StackPanel x:Name="UrlPanel"
                  Visibility="Collapsed"
                  Margin="0,12,0,0"
                  Spacing="4">
        <TextBlock Text="Service URL:"
                   Style="{StaticResource TerminalText}"
                   FontSize="12"
                   Foreground="#808080" />
        <TextBox x:Name="UrlBox"
                 Style="{StaticResource TerminalInput}"
                 FontSize="13"
                 IsTabStop="True" />
      </StackPanel>
    </StackPanel>

    <!-- Bottom-left env button -->
    <Button Background="Transparent" BorderThickness="0" Padding="8"
            VerticalAlignment="Bottom" HorizontalAlignment="Left"
            Margin="16,0,0,16"
            Click="OnEnvClick"
            ToolTipService.ToolTip="Environment Configuration">
      <TextBlock Text=">env"
                 Style="{StaticResource TerminalText}"
                 FontSize="12"
                 Foreground="#555555" />
    </Button>
  </Grid>
</Page>
