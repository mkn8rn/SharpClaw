<Page x:Class="SharpClaw.Presentation.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      NavigationCacheMode="Required"
      Background="Black">

  <Page.Resources>
    <Style x:Key="TerminalText" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="Consolas, Courier New, monospace" />
    </Style>
    <Style x:Key="TerminalInput" TargetType="TextBox">
      <Setter Property="FontFamily" Value="Consolas, Courier New, monospace" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="#00FF00" />
      <Setter Property="Background" Value="#1A1A1A" />
      <Setter Property="BorderBrush" Value="#333333" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="PlaceholderForeground" Value="#555555" />
    </Style>
    <Style x:Key="TerminalPasswordInput" TargetType="PasswordBox">
      <Setter Property="FontFamily" Value="Consolas, Courier New, monospace" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="#00FF00" />
      <Setter Property="Background" Value="#1A1A1A" />
      <Setter Property="BorderBrush" Value="#333333" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="PlaceholderForeground" Value="#555555" />
    </Style>
    <Style x:Key="TerminalButton" TargetType="Button">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Padding" Value="8,8" />
      <Setter Property="Background" Value="#1A1A1A" />
      <Setter Property="BorderBrush" Value="#333333" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style x:Key="TerminalLink" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
  </Page.Resources>

  <Grid HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">

    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                MinWidth="380">

      <!-- Title -->
      <TextBlock Text="SharpClaw"
                 Style="{StaticResource TerminalText}"
                 FontSize="28"
                 FontWeight="Bold"
                 Foreground="#00FF00"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,8" />

      <!-- Mode header -->
      <TextBlock x:Name="HeaderBlock"
                 Text="> Authenticate to continue"
                 Style="{StaticResource TerminalText}"
                 FontSize="14"
                 Foreground="#808080"
                 Margin="0,0,0,12" />

      <!-- Username -->
      <TextBlock Text="username:"
                 Style="{StaticResource TerminalText}"
                 FontSize="13"
                 Foreground="#CCCCCC" />
      <TextBox x:Name="UsernameBox"
               Style="{StaticResource TerminalInput}"
               TextChanged="OnCredentialChanged"
               PlaceholderText="admin"
               HorizontalAlignment="Stretch" />

      <!-- Password -->
      <TextBlock Text="password:"
                 Style="{StaticResource TerminalText}"
                 FontSize="13"
                 Foreground="#CCCCCC"
                 Margin="0,8,0,0" />
      <PasswordBox x:Name="PasswordBox"
                   Style="{StaticResource TerminalPasswordInput}"
                   PasswordChanged="OnCredentialChanged"
                   PlaceholderText="••••••••"
                   HorizontalAlignment="Stretch" />

      <!-- Confirm password (register mode only) -->
      <TextBlock x:Name="ConfirmLabel"
                 Text="confirm password:"
                 Style="{StaticResource TerminalText}"
                 FontSize="13"
                 Foreground="#CCCCCC"
                 Margin="0,8,0,0"
                 Visibility="Collapsed" />
      <PasswordBox x:Name="ConfirmPasswordBox"
                   Style="{StaticResource TerminalPasswordInput}"
                   PlaceholderText="••••••••"
                   HorizontalAlignment="Stretch"
                   Visibility="Collapsed" />

      <!-- Status / error message -->
      <TextBlock x:Name="StatusBlock"
                 Style="{StaticResource TerminalText}"
                 FontSize="13"
                 Foreground="#FF4444"
                 Visibility="Collapsed"
                 Margin="0,4,0,0" />

      <!-- Submit button -->
      <Button x:Name="SubmitButton"
              Style="{StaticResource TerminalButton}"
              Click="OnSubmitClick"
              Margin="0,12,0,0">
        <TextBlock x:Name="SubmitLabel"
                   Text="[ Login ]"
                   Style="{StaticResource TerminalText}"
                   FontSize="14"
                   Foreground="#00FF00"
                   HorizontalAlignment="Center" />
      </Button>

      <!-- Toggle mode link -->
      <Button x:Name="ToggleModeButton"
              Style="{StaticResource TerminalLink}"
              Click="OnToggleModeClick"
              Margin="0,4,0,0">
        <TextBlock x:Name="ToggleModeLabel"
                   Text="> No account? Register"
                   Style="{StaticResource TerminalText}"
                   FontSize="12"
                   Foreground="#808080" />
      </Button>

      <!-- Cursor -->
      <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
        <TextBlock x:Name="CursorCommandBlock"
                   Text=""
                   Style="{StaticResource TerminalText}"
                   FontSize="14"
                   Foreground="#00FF00" />
        <TextBlock x:Name="CursorBlock"
                   Text="_"
                   Style="{StaticResource TerminalText}"
                   FontSize="14"
                   Foreground="#00FF00" />
      </StackPanel>
    </StackPanel>
  </Grid>
</Page>
