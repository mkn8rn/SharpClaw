<Page x:Class="SharpClaw.Presentation.LegalNoticesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      NavigationCacheMode="Required"
      Background="Black">

  <Grid Background="#0D0D0D">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition />
    </Grid.RowDefinitions>

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="24,20,24,12" Spacing="8">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <Button Background="Transparent" BorderThickness="0" Padding="4"
                Click="OnBackClick"
                ToolTipService.ToolTip="Back">
          <TextBlock Text="‹"
                     Style="{StaticResource TerminalText}"
                     FontSize="18"
                     FontWeight="Bold"
                     Foreground="#00FF00" />
        </Button>
        <TextBlock Text="Legal Notices"
                   Style="{StaticResource TerminalText}"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="#00FF00"
                   VerticalAlignment="Center" />
      </StackPanel>
      <Border Height="1" Background="#1A1A1A" />
    </StackPanel>

    <!-- Content -->
    <ScrollViewer Grid.Row="1" Margin="24,0,24,24">
      <TextBlock x:Name="PolicyText"
                 Style="{StaticResource TerminalText}"
                 FontSize="12"
                 Foreground="#00FF00"
                 TextWrapping="Wrap"
                 IsTextSelectionEnabled="True" />
    </ScrollViewer>
  </Grid>
</Page>
