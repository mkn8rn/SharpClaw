<UserControl x:Class="SharpClaw.Presentation.TerminalMenuButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
  <Button x:Name="InnerButton"
          Style="{StaticResource MenuButton}"
          Click="OnClick"
          PointerEntered="OnPointerOver"
          PointerExited="OnPointerOut">
    <StackPanel Orientation="Horizontal" Spacing="10">
      <TextBlock Text="›"
                 Style="{StaticResource TerminalText}"
                 FontSize="14"
                 Foreground="#00FF00" />
      <TextBlock x:Name="LabelBlock"
                 Style="{StaticResource TerminalText}"
                 FontSize="14"
                 Foreground="#E0E0E0" />
      <TextBlock x:Name="DescriptionBlock"
                 Style="{StaticResource TerminalText}"
                 FontSize="12"
                 Foreground="#808080"
                 VerticalAlignment="Center" />
    </StackPanel>
  </Button>
</UserControl>
