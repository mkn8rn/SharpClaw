<Page x:Class="SharpClaw.Presentation.UserGuidePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      NavigationCacheMode="Required"
      Background="Black">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="260" />
      <ColumnDefinition Width="1" />
      <ColumnDefinition />
    </Grid.ColumnDefinitions>

    <!-- Left navigation sidebar -->
    <Grid Grid.Column="0" Background="#0D0D0D">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- Header -->
      <StackPanel Grid.Row="0" Margin="16,16,16,12">
        <TextBlock Text="User Guide"
                   Style="{StaticResource TerminalText}"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="#00FF00" />
        <Border Height="1" Background="#1A1A1A" Margin="0,8,0,0" />
      </StackPanel>

      <!-- Guide topics list -->
      <ScrollViewer Grid.Row="1">
        <StackPanel x:Name="TopicsPanel" Spacing="0" Margin="8,0,8,8" />
      </ScrollViewer>

      <!-- Footer -->
      <StackPanel Grid.Row="2" Margin="16,0,16,12" Spacing="6">
        <Border Height="1" Background="#1A1A1A" Margin="0,0,0,4" />
        <Button Background="Transparent" BorderThickness="0" Padding="0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left"
                Click="OnBackClick">
          <TextBlock Text="&lt; Back to Chat"
                     Style="{StaticResource TerminalText}"
                     FontSize="12"
                     Foreground="#808080" />
        </Button>
      </StackPanel>
    </Grid>

    <!-- Divider -->
    <Border Grid.Column="1" Background="#1A1A1A" />

    <!-- Right content area -->
    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition />
      </Grid.RowDefinitions>

      <!-- Content header -->
      <StackPanel Grid.Row="0" Margin="24,20,24,12" Spacing="8">
        <TextBlock x:Name="ContentTitle"
                   Text="Welcome"
                   Style="{StaticResource TerminalText}"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="#00FF00" />
        <Border Height="1" Background="#1A1A1A" />
      </StackPanel>

      <!-- Markdown content -->
      <ScrollViewer Grid.Row="1" Margin="24,0,24,24">
        <TextBlock x:Name="ContentText"
                   Style="{StaticResource TerminalText}"
                   FontSize="12"
                   Foreground="#CCCCCC"
                   TextWrapping="Wrap"
                   IsTextSelectionEnabled="True" />
      </ScrollViewer>
    </Grid>
  </Grid>
</Page>
