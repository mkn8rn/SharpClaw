<Page x:Class="SharpClaw.Presentation.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:SharpClaw.Presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      NavigationCacheMode="Required"
      Background="Black">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="220" />
      <ColumnDefinition Width="1" />
      <ColumnDefinition />
    </Grid.ColumnDefinitions>

    <!-- Left tab sidebar -->
    <Grid Grid.Column="0" Background="#0D0D0D">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- Header -->
      <StackPanel Grid.Row="0" Margin="16,16,16,12">
        <TextBlock Text="Settings"
                   Style="{StaticResource TerminalText}"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="#00FF00" />
        <Border Height="1" Background="#1A1A1A" Margin="0,8,0,0" />
      </StackPanel>

      <!-- Tab list -->
      <ScrollViewer Grid.Row="1">
        <StackPanel x:Name="TabPanel" Spacing="0" Margin="8,0,8,8" />
      </ScrollViewer>

      <!-- Footer -->
      <StackPanel Grid.Row="2" Margin="16,0,16,12" Spacing="6">
        <Border Height="1" Background="#1A1A1A" Margin="0,0,0,4" />
        <Button Background="Transparent" BorderThickness="0" Padding="0"
                Click="OnEnvClick">
          <TextBlock Text=">env"
                     Style="{StaticResource TerminalText}"
                     FontSize="12"
                     Foreground="#555555" />
        </Button>
        <Button Background="Transparent" BorderThickness="0" Padding="0"
                Click="OnBackClick">
          <TextBlock Text="&lt; Back to Chat"
                     Style="{StaticResource TerminalText}"
                     FontSize="12"
                     Foreground="#808080" />
        </Button>
        <local:TerminalCursor x:Name="Cursor" Margin="0,4,0,0" />
      </StackPanel>
    </Grid>

    <!-- Divider -->
    <Border Grid.Column="1" Background="#1A1A1A" />

    <!-- Right content area -->
    <ScrollViewer Grid.Column="2" Margin="16,16,24,16">
      <StackPanel x:Name="ContentPanel" Spacing="12" MaxWidth="640" HorizontalAlignment="Left" />
    </ScrollViewer>
  </Grid>
</Page>
