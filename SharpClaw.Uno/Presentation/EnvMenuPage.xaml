<Page x:Class="SharpClaw.Presentation.EnvMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      NavigationCacheMode="Required"
      Background="Black">

  <Grid VerticalAlignment="Stretch">
    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12"
                MinWidth="380"
                MaxWidth="480">

      <!-- Header -->
      <StackPanel Orientation="Horizontal" Spacing="12">
        <Button Background="Transparent" BorderThickness="0" Padding="4"
                Click="OnBackClick"
                ToolTipService.ToolTip="Back">
          <TextBlock Text="‹"
                     Style="{StaticResource TerminalText}"
                     FontSize="18"
                     FontWeight="Bold"
                     Foreground="#00FF00" />
        </Button>
        <TextBlock Text="Environment Configuration"
                   Style="{StaticResource TerminalText}"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="#00FF00"
                   VerticalAlignment="Center" />
      </StackPanel>

      <TextBlock Text="> Select a target to configure"
                 Style="{StaticResource TerminalText}"
                 FontSize="13"
                 Foreground="#808080"
                 Margin="0,4,0,0" />

      <Border Height="1" Background="#1A1A1A" />

      <!-- Application Core -->
      <Button Style="{StaticResource TerminalButton}"
              Click="OnAppCoreClick"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Left"
              Padding="12,10">
        <StackPanel Spacing="2">
          <TextBlock Text="› Application Core"
                     Style="{StaticResource TerminalText}"
                     FontSize="14"
                     Foreground="#00FF00" />
          <TextBlock Text="  API server, admin seed, encryption, database, local inference"
                     Style="{StaticResource TerminalText}"
                     FontSize="11"
                     Foreground="#666666" />
        </StackPanel>
      </Button>

      <!-- Application Interface -->
      <Button Style="{StaticResource TerminalButton}"
              Click="OnAppInterfaceClick"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Left"
              Padding="12,10">
        <StackPanel Spacing="2">
          <TextBlock Text="› Application Interface"
                     Style="{StaticResource TerminalText}"
                     FontSize="14"
                     Foreground="#00FF00" />
          <TextBlock Text="  Client API endpoint, UI settings"
                     Style="{StaticResource TerminalText}"
                     FontSize="11"
                     Foreground="#666666" />
        </StackPanel>
      </Button>

      <!-- Public Gateway -->
      <Button Style="{StaticResource TerminalButton}"
              Click="OnGatewayClick"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Left"
              Padding="12,10">
        <StackPanel Spacing="2">
          <TextBlock Text="› Public Gateway"
                     Style="{StaticResource TerminalText}"
                     FontSize="14"
                     Foreground="#00FF00" />
          <TextBlock Text="  Gateway port, endpoint toggles, bot integrations"
                     Style="{StaticResource TerminalText}"
                     FontSize="11"
                     Foreground="#666666" />
        </StackPanel>
      </Button>

      <!-- Status message (admin gate, errors) -->
      <TextBlock x:Name="StatusBlock"
                 Style="{StaticResource TerminalText}"
                 FontSize="12"
                 Foreground="#FF4444"
                 Visibility="Collapsed"
                 TextWrapping="Wrap" />

    </StackPanel>
  </Grid>
</Page>
