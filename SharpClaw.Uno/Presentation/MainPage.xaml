<Page x:Class="SharpClaw.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:SharpClaw.Presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      NavigationCacheMode="Required"
      Background="Black">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="280" />
      <ColumnDefinition Width="1" />
      <ColumnDefinition />
    </Grid.ColumnDefinitions>

    <!-- ═══ Left sidebar ═══ -->
    <Grid Grid.Column="0" Background="#0D0D0D">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- Sidebar header -->
      <StackPanel Grid.Row="0" Margin="16,16,16,8">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="SharpClaw"
                     Style="{StaticResource TerminalText}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="#00FF00"
                     VerticalAlignment="Center" />
          <TextBlock Text="alpha test"
                     Style="{StaticResource TerminalText}"
                     FontSize="10"
                     Foreground="#00FF00"
                     VerticalAlignment="Center" />
        </StackPanel>
      </StackPanel>

      <!-- New channel button -->
      <Button Grid.Row="1"
              Style="{StaticResource TerminalButton}"
              Click="OnNewChannelClick"
              PointerEntered="OnNewChannelPointerEntered"
              PointerExited="OnNewChannelPointerExited"
              Margin="16,0,16,8">
        <TextBlock Text="+ New Channel"
                   Style="{StaticResource TerminalText}"
                   FontSize="12"
                   Foreground="#00FF00"
                   HorizontalAlignment="Center" />
      </Button>

      <!-- Channel list grouped by context -->
      <ScrollViewer Grid.Row="2" Margin="0,0,0,0">
        <StackPanel x:Name="SidebarPanel" Spacing="0" Margin="8,0,8,8" />
      </ScrollViewer>

      <!-- Sidebar footer -->
      <StackPanel Grid.Row="3" Margin="16,0,16,12" Spacing="6">
        <Border Height="1" Background="#1A1A1A" Margin="0,0,0,4" />
        <Button Background="Transparent" BorderThickness="0" Padding="0"
                Click="OnDashboardClick">
          <TextBlock Text="› Dashboard"
                     Style="{StaticResource TerminalText}"
                     FontSize="12"
                     Foreground="#808080" />
        </Button>
        <Button Background="Transparent" BorderThickness="0" Padding="0"
                Click="OnLogoutClick">
          <TextBlock Text="› Logout"
                     Style="{StaticResource TerminalText}"
                     FontSize="12"
                     Foreground="#808080" />
        </Button>
        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,6,0,0">
          <Button Background="Transparent" BorderThickness="0" Padding="4"
                  Click="OnMatrixCommunityClick"
                  ToolTipService.ToolTip="Matrix Community">
            <TextBlock Text="M"
                       Style="{StaticResource TerminalText}"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="#00FF00" />
          </Button>
          <Button Background="Transparent" BorderThickness="0" Padding="4"
                  Click="OnCreatorBlogClick"
                  ToolTipService.ToolTip="Creator's Blog">
            <TextBlock Text=">_"
                       Style="{StaticResource TerminalText}"
                       FontSize="13"
                       FontWeight="Bold"
                       Foreground="#00FF00" />
          </Button>
        </StackPanel>
      </StackPanel>
    </Grid>

    <!-- Divider -->
    <Border Grid.Column="1" Background="#1A1A1A" />

    <!-- ═══ Right chat area ═══ -->
    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- Chat header -->
      <StackPanel Grid.Row="0" Margin="20,16,20,0" Spacing="4">
        <TextBlock x:Name="ChatTitleBlock"
                   Text="> Select or create a channel"
                   Style="{StaticResource TerminalText}"
                   FontSize="14"
                   Foreground="#808080" />
        <TextBlock x:Name="ChatAgentBlock"
                   Style="{StaticResource TerminalText}"
                   FontSize="11"
                   Foreground="#999999" />
        <StackPanel x:Name="AgentSelectorPanel"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="0,4,0,0">
          <TextBlock Text="agent:"
                     Style="{StaticResource TerminalText}"
                     FontSize="11"
                     Foreground="#999999"
                     VerticalAlignment="Center" />
          <ComboBox x:Name="AgentSelector"
                    FontFamily="Consolas, Courier New, monospace"
                    FontSize="11"
                    Background="#1A1A1A"
                    Foreground="#CCCCCC"
                    BorderBrush="#333333"
                    BorderThickness="1"
                    MinWidth="220"
                    Padding="6,4"
                    SelectionChanged="OnAgentSelectionChanged" />
        </StackPanel>
        <StackPanel x:Name="ThreadSelectorPanel"
                    Orientation="Horizontal"
                    Spacing="8"
                    Visibility="Collapsed"
                    Margin="0,4,0,0">
          <TextBlock Text="thread:"
                     Style="{StaticResource TerminalText}"
                     FontSize="11"
                     Foreground="#999999"
                     VerticalAlignment="Center" />
          <ComboBox x:Name="ThreadSelector"
                    FontFamily="Consolas, Courier New, monospace"
                    FontSize="11"
                    Background="#1A1A1A"
                    Foreground="#CCCCCC"
                    BorderBrush="#333333"
                    BorderThickness="1"
                    MinWidth="220"
                    Padding="6,4"
                    SelectionChanged="OnThreadSelectionChanged" />
          <Button Background="Transparent" BorderThickness="0" Padding="4,2"
                  Click="OnAddThreadClick"
                  ToolTipService.ToolTip="New thread"
                  VerticalAlignment="Center">
            <TextBlock Text="+"
                       Style="{StaticResource TerminalText}"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="#00FF00" />
          </Button>
        </StackPanel>
        <TextBlock x:Name="OneOffWarning"
                   Text="⚠ One-off mode — the agent has no conversation history. Select a thread to enable context."
                   Style="{StaticResource TerminalText}"
                   FontSize="10"
                   Foreground="#FF4444"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"
                   Margin="0,6,0,0" />
        <Border Height="1" Background="#1A1A1A" Margin="0,8,0,0" />
      </StackPanel>

      <!-- Messages -->
      <ScrollViewer x:Name="MessagesScroller" Grid.Row="1" Margin="20,8,20,0">
        <StackPanel x:Name="MessagesPanel" Spacing="12" />
      </ScrollViewer>

      <!-- Input area -->
      <Grid Grid.Row="2" Margin="20,8,20,16">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBox x:Name="MessageInput"
                   Style="{StaticResource TerminalInput}"
                   PlaceholderText="Type a message..."
                   KeyDown="OnMessageKeyDown"
                   TextChanged="OnMessageTextChanged"
                   HorizontalAlignment="Stretch" />
          <Button Grid.Column="1"
                  Style="{StaticResource TerminalButton}"
                  Click="OnSendClick"
                  Margin="8,0,0,0"
                  x:Name="SendButton">
            <TextBlock Text="Send"
                       Style="{StaticResource TerminalText}"
                       FontSize="13"
                       Foreground="#00FF00" />
          </Button>
        </Grid>
        <local:TerminalCursor x:Name="Cursor" Grid.Row="1" Margin="0,8,0,0" />
      </Grid>
    </Grid>
  </Grid>
</Page>
