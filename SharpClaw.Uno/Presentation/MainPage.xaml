<Page x:Class="SharpClaw.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      NavigationCacheMode="Required"
      Background="Black">

  <Page.Resources>
    <Style x:Key="TerminalText" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="Consolas, Courier New, monospace" />
    </Style>
    <Style x:Key="MenuButton" TargetType="Button">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="Background" Value="#1A1A1A" />
      <Setter Property="BorderBrush" Value="#2A2A2A" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>
  </Page.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="24,20,24,0" Spacing="4">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <TextBlock Text="SharpClaw"
                   Style="{StaticResource TerminalText}"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#00FF00"
                   VerticalAlignment="Center" />
        <TextBlock x:Name="VersionBlock"
                   Text="v1.0"
                   Style="{StaticResource TerminalText}"
                   FontSize="12"
                   Foreground="#666666"
                   VerticalAlignment="Center" />
      </StackPanel>
      <TextBlock x:Name="WelcomeBlock"
                 Text="> Dashboard"
                 Style="{StaticResource TerminalText}"
                 FontSize="13"
                 Foreground="#808080"
                 Margin="0,4,0,0" />
      <Border Height="1" Background="#1A1A1A" Margin="0,12,0,0" />
    </StackPanel>

    <!-- Menu -->
    <ScrollViewer Grid.Row="1" Margin="24,12,24,0">
      <StackPanel x:Name="MenuPanel" Spacing="2">

        <!-- Section: Models -->
        <TextBlock Text="── Models ──"
                   Style="{StaticResource TerminalText}"
                   FontSize="11"
                   Foreground="#666666"
                   Margin="0,8,0,6" />

        <Button Style="{StaticResource MenuButton}" Tag="Providers" Click="OnMenuClick" PointerEntered="OnMenuPointerEntered" PointerExited="OnMenuPointerExited">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="›" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#00FF00" />
            <TextBlock Text="Providers" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#E0E0E0" />
            <TextBlock Text="— API provider connections" Style="{StaticResource TerminalText}" FontSize="12" Foreground="#808080" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <Button Style="{StaticResource MenuButton}" Tag="Models" Click="OnMenuClick" PointerEntered="OnMenuPointerEntered" PointerExited="OnMenuPointerExited">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="›" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#00FF00" />
            <TextBlock Text="Models" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#E0E0E0" />
            <TextBlock Text="— LLM model registry" Style="{StaticResource TerminalText}" FontSize="12" Foreground="#808080" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <Button Style="{StaticResource MenuButton}" Tag="LocalModels" Click="OnMenuClick" PointerEntered="OnMenuPointerEntered" PointerExited="OnMenuPointerExited">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="›" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#00FF00" />
            <TextBlock Text="Local Models" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#E0E0E0" />
            <TextBlock Text="— on-device inference" Style="{StaticResource TerminalText}" FontSize="12" Foreground="#808080" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <!-- Section: Agents -->
        <TextBlock Text="── Agents ──"
                   Style="{StaticResource TerminalText}"
                   FontSize="11"
                   Foreground="#666666"
                   Margin="0,16,0,6" />

        <Button Style="{StaticResource MenuButton}" Tag="Agents" Click="OnMenuClick" PointerEntered="OnMenuPointerEntered" PointerExited="OnMenuPointerExited">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="›" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#00FF00" />
            <TextBlock Text="Agents" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#E0E0E0" />
            <TextBlock Text="— agent profiles &amp; configuration" Style="{StaticResource TerminalText}" FontSize="12" Foreground="#808080" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <Button Style="{StaticResource MenuButton}" Tag="Roles" Click="OnMenuClick" PointerEntered="OnMenuPointerEntered" PointerExited="OnMenuPointerExited">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="›" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#00FF00" />
            <TextBlock Text="Roles" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#E0E0E0" />
            <TextBlock Text="— permission sets &amp; clearance" Style="{StaticResource TerminalText}" FontSize="12" Foreground="#808080" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <Button Style="{StaticResource MenuButton}" Tag="Jobs" Click="OnMenuClick" PointerEntered="OnMenuPointerEntered" PointerExited="OnMenuPointerExited">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="›" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#00FF00" />
            <TextBlock Text="Jobs" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#E0E0E0" />
            <TextBlock Text="— async agent tasks" Style="{StaticResource TerminalText}" FontSize="12" Foreground="#808080" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <!-- Section: Chat -->
        <TextBlock Text="── Chat ──"
                   Style="{StaticResource TerminalText}"
                   FontSize="11"
                   Foreground="#666666"
                   Margin="0,16,0,6" />

        <Button Style="{StaticResource MenuButton}" Tag="Channels" Click="OnMenuClick" PointerEntered="OnMenuPointerEntered" PointerExited="OnMenuPointerExited">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="›" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#00FF00" />
            <TextBlock Text="Channels" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#E0E0E0" />
            <TextBlock Text="— chat channels &amp; threads" Style="{StaticResource TerminalText}" FontSize="12" Foreground="#808080" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <Button Style="{StaticResource MenuButton}" Tag="Contexts" Click="OnMenuClick" PointerEntered="OnMenuPointerEntered" PointerExited="OnMenuPointerExited">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="›" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#00FF00" />
            <TextBlock Text="Contexts" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#E0E0E0" />
            <TextBlock Text="— channel context presets" Style="{StaticResource TerminalText}" FontSize="12" Foreground="#808080" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <!-- Section: Resources -->
        <TextBlock Text="── Resources ──"
                   Style="{StaticResource TerminalText}"
                   FontSize="11"
                   Foreground="#666666"
                   Margin="0,16,0,6" />

        <Button Style="{StaticResource MenuButton}" Tag="Resources" Click="OnMenuClick" PointerEntered="OnMenuPointerEntered" PointerExited="OnMenuPointerExited">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="›" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#00FF00" />
            <TextBlock Text="Resources" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#E0E0E0" />
            <TextBlock Text="— shells, containers, devices" Style="{StaticResource TerminalText}" FontSize="12" Foreground="#808080" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <Button Style="{StaticResource MenuButton}" Tag="Editor" Click="OnMenuClick" PointerEntered="OnMenuPointerEntered" PointerExited="OnMenuPointerExited">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="›" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#00FF00" />
            <TextBlock Text="Editor Sessions" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#E0E0E0" />
            <TextBlock Text="— IDE bridge connections" Style="{StaticResource TerminalText}" FontSize="12" Foreground="#808080" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <Button Style="{StaticResource MenuButton}" Tag="Transcription" Click="OnMenuClick" PointerEntered="OnMenuPointerEntered" PointerExited="OnMenuPointerExited">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="›" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#00FF00" />
            <TextBlock Text="Transcription" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#E0E0E0" />
            <TextBlock Text="— speech-to-text sessions" Style="{StaticResource TerminalText}" FontSize="12" Foreground="#808080" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <!-- Section: System -->
        <TextBlock Text="── System ──"
                   Style="{StaticResource TerminalText}"
                   FontSize="11"
                   Foreground="#666666"
                   Margin="0,16,0,6" />

        <Button Style="{StaticResource MenuButton}" Tag="Auth" Click="OnMenuClick" PointerEntered="OnMenuPointerEntered" PointerExited="OnMenuPointerExited">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="›" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#00FF00" />
            <TextBlock Text="Auth &amp; Users" Style="{StaticResource TerminalText}" FontSize="14" Foreground="#E0E0E0" />
            <TextBlock Text="— sessions &amp; tokens" Style="{StaticResource TerminalText}" FontSize="12" Foreground="#808080" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

      </StackPanel>
    </ScrollViewer>

    <!-- Footer -->
    <StackPanel Grid.Row="2" Margin="24,8,24,16" Spacing="8">
      <Border Height="1" Background="#1A1A1A" />
      <StackPanel Orientation="Horizontal" Spacing="16">
        <Button Background="Transparent" BorderThickness="0" Padding="0"
                Click="OnLogoutClick">
          <TextBlock Text="> Logout"
                     Style="{StaticResource TerminalText}"
                     FontSize="12"
                     Foreground="#808080" />
        </Button>
        <TextBlock x:Name="StatusBlock"
                   Style="{StaticResource TerminalText}"
                   FontSize="12"
                   Foreground="#808080"
                   VerticalAlignment="Center" />
      </StackPanel>
      <StackPanel Orientation="Horizontal">
        <TextBlock x:Name="CursorCommandBlock"
                   Text=""
                   Style="{StaticResource TerminalText}"
                   FontSize="14"
                   Foreground="#00FF00" />
        <TextBlock x:Name="CursorBlock"
                   Text="_"
                   Style="{StaticResource TerminalText}"
                   FontSize="14"
                   Foreground="#00FF00" />
      </StackPanel>
    </StackPanel>
  </Grid>
</Page>
