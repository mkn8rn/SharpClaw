<ResourceDictionary x:Class="SharpClaw.Styles.TerminalStyles"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Base monospace text -->
  <Style x:Key="TerminalText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Consolas, Courier New, monospace" />
  </Style>

  <!-- Green text input -->
  <Style x:Key="TerminalInput" TargetType="TextBox">
    <Setter Property="FontFamily" Value="Consolas, Courier New, monospace" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Foreground" Value="#00FF00" />
    <Setter Property="Background" Value="#1A1A1A" />
    <Setter Property="BorderBrush" Value="#333333" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="PlaceholderForeground" Value="#555555" />
  </Style>

  <!-- Green password input -->
  <Style x:Key="TerminalPasswordInput" TargetType="PasswordBox">
    <Setter Property="FontFamily" Value="Consolas, Courier New, monospace" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Foreground" Value="#00FF00" />
    <Setter Property="Background" Value="#1A1A1A" />
    <Setter Property="BorderBrush" Value="#333333" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="PlaceholderForeground" Value="#555555" />
  </Style>

  <!-- Solid action button -->
  <Style x:Key="TerminalButton" TargetType="Button">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Padding" Value="8,8" />
    <Setter Property="Background" Value="#1A1A1A" />
    <Setter Property="BorderBrush" Value="#333333" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <!-- Transparent link-style button -->
  <Style x:Key="TerminalLink" TargetType="Button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <!-- Menu row button -->
  <Style x:Key="MenuButton" TargetType="Button">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="Background" Value="#1A1A1A" />
    <Setter Property="BorderBrush" Value="#2A2A2A" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>

</ResourceDictionary>