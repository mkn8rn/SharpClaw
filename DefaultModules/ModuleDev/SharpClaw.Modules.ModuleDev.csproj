<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Copy NuGet runtime DLLs into bin so the API's CopyBundledModules target picks them up. -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="SharpClaw.Contracts" />
    <ProjectReference Include="..\..\SharpClaw.Utils\SharpClaw.Utils.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="SharpClaw.Tests" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Templates\ModuleClass.cs.template" WithCulture="false" />
    <EmbeddedResource Include="Templates\ProjectFile.csproj.template" WithCulture="false" />
    <EmbeddedResource Include="Templates\Manifest.json.template" WithCulture="false" />
    <EmbeddedResource Include="Templates\NodePackage.json.template" WithCulture="false" />
    <EmbeddedResource Include="Templates\NodeModule.mjs.template" WithCulture="false" />
    <EmbeddedResource Include="Templates\NodeManifest.json.template" WithCulture="false" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="module.json" Link="modules\sharpclaw_module_dev\module.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Security.Cryptography.Xml" />
  </ItemGroup>

</Project>
