<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- Force NuGet package DLLs (e.g. Whisper.net) to be physically copied to the output folder.
         Without this the SDK leaves them as deps.json cache references, which the host's
         AssemblyLoadContext cannot resolve when loading the module at runtime. -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\SharpClaw.Contracts\SharpClaw.Contracts.csproj" />
    <ProjectReference Include="..\..\SharpClaw.Utils\SharpClaw.Utils.csproj" />
    <ProjectReference Include="..\SystemAudio\SharpClaw.Modules.SystemAudio.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Security.Cryptography.Xml" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="module.json" Link="modules\sharpclaw_transcription\module.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\transcription-language-seeds.json" LogicalName="SharpClaw.Modules.Transcription.transcription-language-seeds.json" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="LocalInference\" />
  </ItemGroup>

</Project>
