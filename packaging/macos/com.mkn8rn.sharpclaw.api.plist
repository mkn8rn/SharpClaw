<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mkn8rn.sharpclaw.api</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/sharpclaw/api/SharpClaw.Application.API</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/usr/local/sharpclaw/api</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/var/log/sharpclaw/api.out.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/sharpclaw/api.err.log</string>
</dict>
</plist>
