  // ── Database (JSON Persistence — ACID) ─────────────────────────────
  // Controls durability, integrity, and recovery of the JSON
  // file persistence layer (StorageMode=JsonFile only).
  // All keys are optional; documented defaults shown.
  //
  // FsyncOnWrite (default true): fsync .tmp before atomic rename.
  //   Set false only in dev where crash-safety is acceptable.
  //
  // IndexRescanIntervalMinutes (default 60): cold entity index rebuild
  //   interval. 0 = startup-only rebuild, no periodic rescan.
  //
  // QuarantineMaxAgeDays (default 30): corrupt quarantined files older
  //   than this are deleted on startup. 0 = keep forever.
  //
  // EnableChecksums (default true): SHA-256 per-file manifests + HMAC
  //   signature. Mismatch → file is quarantined automatically.
  // VerifyChecksumsOnRead (default false): verify on every read.
  //   Enables runtime detection at a CPU cost.
  //
  // EnableEventLog (default false): append-only JSONL audit trail,
  //   encrypted per-line when EncryptAtRest is on.
  // EventLogRetentionDays (default 7): keep this many days of log files.
  //
  // EnableSnapshots (default false): periodic ZIP snapshots of all
  //   entity directories, used as fallback when quarantine fires.
  // SnapshotIntervalHours (default 24): hours between snapshots.
  // SnapshotRetentionCount (default 3): keep N most recent ZIPs.
  //
  // AsyncFlush (default true): background worker flushes SaveChanges
  //   to disk; write-through overlay keeps reads consistent.
  //
  //"Database": {
  //  "FsyncOnWrite": "true",
  //  "IndexRescanIntervalMinutes": "60",
  //  "QuarantineMaxAgeDays": "30",
  //  "EnableChecksums": "true",
  //  "VerifyChecksumsOnRead": "false",
  //  "EnableEventLog": "false",
  //  "EventLogRetentionDays": "7",
  //  "EnableSnapshots": "false",
  //  "SnapshotIntervalHours": "24",
  //  "SnapshotRetentionCount": "3",
  //  "AsyncFlush": "true"
  //}
