{
  // SharpClaw Environment Configuration
  // Values here are loaded for all environments.

  // ── Encryption ─────────────────────────────────────────────────
  // Base64-encoded 256-bit key used for ALL encryption at rest:
  // provider API keys, bot tokens, DB connection strings, and (when
  // EncryptDatabase is true) every JSON data file on disk.
  //
  // ⚠️  WARNING: CHANGING THIS KEY AFTER DATA HAS BEEN WRITTEN WILL
  // ⚠️  MAKE ALL PREVIOUSLY ENCRYPTED DATA PERMANENTLY UNREADABLE.
  // ⚠️  THERE IS NO RECOVERY. BACK UP THE CURRENT KEY BEFORE CHANGING.
  // ⚠️  If not set, a key is auto-generated and persisted at
  // ⚠️  %LOCALAPPDATA%/SharpClaw/.encryption-key — that file IS
  // ⚠️  the key. Losing it is equivalent to losing the data.
  //"Encryption": {
  //  "Key": "",
  //
  //  ── Database encryption ────────────────────────────────────
  //  Encrypt all JSON data files (entity + join table) on disk.
  //  Default: true. Read path always auto-detects and decrypts
  //  regardless of this flag, so toggling to false is non-destructive
  //  (new writes become plaintext, existing encrypted files still load).
  //  "EncryptDatabase": "true",
  //
  //  ── Provider key encryption ────────────────────────────────
  //  Encrypt provider API keys, bot tokens, and DB connection
  //  strings stored in the database.  Default: true.
  //
  //  ⚠️  WARNING: SETTING THIS TO FALSE STORES SECRETS IN PLAINTEXT
  //  ⚠️  INSIDE THE DATABASE (InMemory JSON files or Postgres rows).
  //  ⚠️  THIS IS STRONGLY DISCOURAGED FOR ANY DEPLOYMENT.
  //  ⚠️  Only intended for debugging encryption-related issues.
  //  "EncryptProviderKeys": "true"
  //},

