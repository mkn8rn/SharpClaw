{
  // SharpClaw Core environment configuration.
  //
  // This file is JSON with comments. The build copies it to .env when a
  // project has no local .env yet. The running Core process then encrypts
  // the plaintext .env on first read when an encryption key is available.
  // Prefer changing these settings through the application env editor.

  // Encryption.
  //
  // Key is a Base64 encoded 256-bit value. Leave it commented to let
  // SharpClaw create and persist a per-instance key. Changing or losing
  // this key makes encrypted provider keys, connection strings, and
  // encrypted JSON data unreadable.
  "Encryption": {
    //"Key": "",
    "EncryptDatabase": "true",
    "EncryptProviderKeys": "true"
  },

  // JWT authentication.
  //
  // Secret signs access tokens. Leave it commented to let SharpClaw create
  // and persist a per-instance secret. AccessTokenLifetime and
  // RefreshTokenLifetime use TimeSpan text, so "00:30:00" means thirty
  // minutes and "30.00:00:00" means thirty days.
  "Jwt": {
    //"Secret": "",
    "Issuer": "SharpClaw",
    "Audience": "SharpClaw",
    "AccessTokenLifetime": "00:30:00",
    "RefreshTokenLifetime": "30.00:00:00"
  },

  // Development authentication switches.
  //
  // These should stay false outside controlled local testing. Disabling the
  // API key check removes the local-process gate. Disabling the access-token
  // check lets non-anonymous endpoints run without a Bearer token, although
  // endpoints that need a user id still need a valid token to populate the
  // session. DisableCustomProviderParameters strips the free-form provider
  // parameter dictionary before a provider call while leaving typed model
  // and agent parameters intact.
  "Auth": {
    "DisableApiKeyCheck": "false",
    "DisableAccessTokenCheck": "false"
  },
  "Agent": {
    "DisableCustomProviderParameters": "false"
  },

  // Chat pipeline switches.
  //
  // DisableDefaultHeaders skips the generated per-message metadata header
  // while still allowing explicit custom headers on agents or channels.
  // DisableDefaultSystemPrompt skips the core-generated native-tool
  // instruction suffix while preserving the agent's own configured system
  // prompt. DisableHeaderTagExpansion treats explicit custom headers as
  // literal text, so built-in tags, resource tags, and module tags are not
  // resolved.
  // DisableModuleHeaderTags prevents module-owned custom header tags from
  // executing. CacheMaxMegabytes sets the unified chat cache memory budget
  // for header state and channel/thread/agent token totals. Set it to 0
  // to disable chat caching.
  "Chat": {
    "DisableDefaultHeaders": "false",
    "DisableDefaultSystemPrompt": "false",
    "DisableHeaderTagExpansion": "false",
    "DisableModuleHeaderTags": "false",
    "CacheMaxMegabytes": "2048"
  },

  // Agent Orchestration module switches. DisableAccessibleThreadsHeader
  // makes the module-owned {{accessible-threads}} custom-header tag resolve
  // to an empty string. It does not disable the module's explicit
  // cross-thread tools or permission model.
  "AgentOrchestration": {
    "DisableAccessibleThreadsHeader": "false"
  },

  // Database.
  //
  // Provider may be JsonFile, Postgres, SqlServer, or SQLite. MySql and
  // Oracle are known enum values but are not wired for EF Core 10 here.
  // Relational providers require the matching ConnectionStrings entry.
  // Database migrations are manual only; this template does not run them.
  "Database": {
    "Provider": "JsonFile",
    "FsyncOnWrite": "true",
    "IndexRescanIntervalMinutes": "60",
    "QuarantineMaxAgeDays": "30",
    "EnableChecksums": "true",
    "VerifyChecksumsOnRead": "false",
    "EnableEventLog": "false",
    "EventLogRetentionDays": "7",
    "EnableSnapshots": "false",
    "SnapshotIntervalHours": "24",
    "SnapshotRetentionCount": "3",
    "AsyncFlush": "true",
    "EnableDetailedErrors": "true",
    "EnableSensitiveDataLogging": "false"
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Database=sharpclaw;Username=sharpclaw;Password=",
    "SqlServer": "Server=localhost;Database=SharpClaw;Trusted_Connection=True;TrustServerCertificate=True",
    "SQLite": "Data Source=sharpclaw.db"
  },

  // Core process logging.
  //
  // These options are shared by Core, Gateway, and Interface. In Core,
  // RequestLoggingEnabled controls ASP.NET Core request logging through
  // Serilog. FileEnabled writes raw Serilog output to serilog.txt in the
  // current backend instance log folder. The session log provider writes
  // the normal ILogger stream to log.txt, debug-level entries to debug.txt,
  // and exception details to exceptions.txt in the same folder.
  "Logging": {
    "Serilog": {
      "Enabled": "true",
      "ConsoleEnabled": "true",
      "FileEnabled": "true",
      "RequestLoggingEnabled": "true",
      "MinimumLevel": "Information",
      "MicrosoftMinimumLevel": "Warning",
      "AspNetCoreMinimumLevel": "Warning",
      "EntityFrameworkCoreMinimumLevel": "Warning",
      "UnoMinimumLevel": "Warning"
    }
  },

  // Initial admin seed.
  //
  // These credentials create the first user only when the database has no
  // users. ReconcilePermissions keeps the Admin role current when modules
  // add new permission flags or resource access types.
  "Admin": {
    "Username": "admin",
    "Password": "123456",
    "ReconcilePermissions": "true"
  },

  // Local model inference.
  //
  // GpuLayerCount -1 means offload all layers when a GPU backend is
  // available; 0 forces CPU only. KeepLoaded keeps models resident after
  // first use. MaxCachedSessions limits simultaneous cached local sessions.
  // ModelsDirectory is useful when models should live on a shared or larger
  // disk. HuggingFaceToken is used only for gated/private Hugging Face repos
  // and rate-limit relief.
  "Local": {
    "GpuLayerCount": "-1",
    "ContextSize": "8192",
    "KeepLoaded": "true",
    "IdleCooldownMinutes": "5",
    "MaxCachedSessions": "2",
    "ModelsDirectory": "",
    "HuggingFaceToken": ""
  },

  // Core env editor policy.
  //
  // When false, only admins can read or save this Core env file through the
  // API and Uno env editor. The Interface env file is edited directly by the
  // current desktop user and is not controlled by this setting.
  "EnvEditor": {
    "AllowNonAdmin": "false"
  },

  // Unique-name enforcement for common Core entities.
  "UniqueNames": {
    "Agents": "true",
    "Channels": "true",
    "Providers": "true",
    "Models": "true",
    "Roles": "true",
    "Contexts": "true"
  },

  // External modules.
  //
  // Add absolute paths to directories that contain module.json. Runtime-loaded
  // modules are appended here as disabled, then can be enabled after review.
  //"ExternalModules": [
  //  { "Path": "C:\\modules\\Custom.Module\\bin\\Debug\\net10.0", "Enabled": true }
  //],

  // Module host behavior and bundled module enablement.
  //
  // Modules are enabled only when their module id is explicitly true here.
  // The base template enables provider modules and keeps feature/editor
  // modules disabled. The development template turns all bundled modules on.
  "Modules": {
    "CrashOnExternalModuleLoadFailure": "true",
    "EventDispatchTimeoutSeconds": "5",
    "HealthCheckIntervalSeconds": "60",
    "HealthCheckFailureThreshold": "3",
    "HealthCheckTimeoutSeconds": "10",
    "MaxEnvelopeSizeBytes": "1048576",
    "UnloadVerifyMaxAttempts": "10",
    "UnloadVerifyDelayMs": "100",
    "sharpclaw_agent_orchestration": "false",
    "sharpclaw_editor_common": "false",
    "sharpclaw_metrics": "false",
    "sharpclaw_module_dev": "false",
    "sharpclaw_providers_anthropic": "true",
    "sharpclaw_providers_google": "true",
    "sharpclaw_providers_llamasharp": "true",
    "sharpclaw_providers_ollama": "true",
    "sharpclaw_providers_openai_compat": "true",
    "sharpclaw_test_harness": "false",
    "sharpclaw_vs2026_editor": "false",
    "sharpclaw_vscode_editor": "false"
  }
}
