      "MinimumLevel": "Debug",
      "MicrosoftMinimumLevel": "Information",
      "AspNetCoreMinimumLevel": "Information",
      "EntityFrameworkCoreMinimumLevel": "Information",
      "UnoMinimumLevel": "Information"
    }
  },

  "Backend": {
    "Enabled": "true"
  },

  "Gateway": {
    "Enabled": "false",
    "Url": "http://0.0.0.0:48924"
  },

  "Processes": {
    "Persistent": "false",
    "AutoStart": "false"
  }
}
