{
  "name": "Required CI Domains",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": [
        "~DEFAULT_BRANCH",
        "refs/heads/release/**"
      ],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "do_not_enforce_on_create": false,
        "required_status_checks": [
          { "context": "Correctness / API Key Provider" },
          { "context": "Correctness / Architecture Core Dependencies" },
          { "context": "Correctness / Architecture Module Dependencies" },
          { "context": "Correctness / Clients Finish Reasons" },
          { "context": "Correctness / Core Header Tags" },
          { "context": "Correctness / Core Chat Cache" },
          { "context": "Correctness / CLI Channel Commands" },
          { "context": "Correctness / CLI REPL" },
          { "context": "Correctness / Gateway Abstraction Boundaries" },
          { "context": "Correctness / Gateway Internal API Client" },
          { "context": "Correctness / Gateway Synthetic Modules" },
          { "context": "Correctness / Gateway Endpoint Catalog" },
          { "context": "Correctness / Gateway Endpoint Toggles" },
          { "context": "Correctness / Gateway Route Parity" },
          { "context": "Correctness / Gateway Lifecycle" },
          { "context": "Correctness / Gateway Hot Reload" },
          { "context": "Correctness / Gateway Chat Surface" },
          { "context": "Correctness / Gateway Chat Errors And Cancellation" },
          { "context": "Correctness / API Job Contracts" },
          { "context": "Correctness / Gateway Job Contracts" },
          { "context": "Correctness / Frontend Instances" },
          { "context": "Correctness / Frontend Gateway Process" },
          { "context": "Correctness / Frontend Uno Client State" },
          { "context": "Correctness / Persistence Provider Configuration" },
          { "context": "Correctness / JSONColdStore Provider Paths" },
          { "context": "Correctness / Persistence Instances" },
          { "context": "Correctness / Providers Capabilities" },
          { "context": "Correctness / LlamaSharp Schema Conversion" },
          { "context": "Correctness / LlamaSharp Tool Calling" },
          { "context": "Correctness / Tasks Scripts Compiler Parser" },
          { "context": "Correctness / Tasks Scripts Semantics Validator" },
          { "context": "Correctness / Tasks Step Keys" },
          { "context": "Correctness / Tasks Execution Lifecycle" },
          { "context": "Correctness / Tasks Shared Data" },
          { "context": "Correctness / Tasks Triggers" },
          { "context": "Correctness / Chat Prompt Surface" },
          { "context": "Correctness / Chat Tool Permissions" },
          { "context": "Correctness / Chat Costs And Budgets" },
          { "context": "Correctness / Chat Thread History" },
          { "context": "Correctness / Chat Thread Concurrency" },
          { "context": "Correctness / Chat Agent Selection" },
          { "context": "Correctness / Chat Prompt Assembly" },
          { "context": "Correctness / Chat Streaming" },
          { "context": "Correctness / Jobs Direct" },
          { "context": "Correctness / Jobs Lifecycle" },
          { "context": "Correctness / Jobs Streaming" },
          { "context": "Correctness / Tools Inline Permissions" },
          { "context": "Correctness / Tools Arguments Output And Latency" },
          { "context": "Correctness / Tools Provider Stream Bulk" },
          { "context": "Correctness / Tools Provider Stream Cache" },
          { "context": "Correctness / Tools Provider Stream Lifecycle" },
          { "context": "Correctness / Costs Job Accounting" },
          { "context": "Correctness / Costs Streaming" },
          { "context": "Correctness / Costs Multi Agent" },
          { "context": "Correctness / Costs Module Hooks" },
          { "context": "Correctness / Cache Header Invalidations" },
          { "context": "Correctness / Cache Tool Settings" },
          { "context": "Correctness / Agent Orchestration Access" },
          { "context": "Correctness / Agent Orchestration History" },
          { "context": "Correctness / Defaults Mutations" },
          { "context": "Correctness / Defaults Resource Resolution" },
          { "context": "Correctness / Module API Host Startup" },
          { "context": "Correctness / Module Bundled Outputs" },
          { "context": "Correctness / Module External Lifecycle" },
          { "context": "Correctness / Module Foreign Runtime" },
          { "context": "Correctness / Module Sidecar Parity" },
          { "context": "Correctness / Module Harness Integration" },
          { "context": "Correctness / Module Harness Cost And Matrix" },
          { "context": "Correctness / Module Contracts Architecture" },
          { "context": "Correctness / Provider Registration" },
          { "context": "Performance / Streaming End To End" },
          { "context": "Performance / Streaming API" },
          { "context": "Performance / Streaming Gateway" },
          { "context": "Performance / Streaming Concurrency" },
          { "context": "Performance / Chat Non Streaming" },
          { "context": "Performance / Chat Concurrent Throughput" },
          { "context": "Performance / Chat Sequential Warm Cache" },
          { "context": "Performance / Jobs Direct Actions" },
          { "context": "Performance / Jobs Summaries" },
          { "context": "Performance / Jobs Parallel" },
          { "context": "Performance / Tools Permission Checks" },
          { "context": "Performance / Tools Provider Stream Serial" },
          { "context": "Performance / Tools Provider Stream Parallel" },
          { "context": "Performance / Accessible Threads" },
          { "context": "Performance / Prompt Assembly" },
          { "context": "Performance / Cost Lookup" },
          { "context": "Performance / Provider Resolution" },
          { "context": "Performance / Cold Chat Cache" }
        ]
      }
    },
    {
      "type": "pull_request",
      "parameters": {
        "required_approving_review_count": 1,
        "dismiss_stale_reviews_on_push": false,
        "required_reviewers": [],
        "require_code_owner_review": false,
        "require_last_push_approval": false,
        "required_review_thread_resolution": false,
        "allowed_merge_methods": [
          "merge",
          "squash"
        ]
      }
    },
    {
      "type": "code_quality",
      "parameters": {
        "severity": "errors"
      }
    },
    {
      "type": "code_scanning",
      "parameters": {
        "code_scanning_tools": [
          {
            "tool": "CodeQL",
            "security_alerts_threshold": "medium_or_higher",
            "alerts_threshold": "errors"
          }
        ]
      }
    }
  ],
  "bypass_actors": [
    {
      "actor_id": 5,
      "actor_type": "RepositoryRole",
      "bypass_mode": "always"
    }
  ]
}
