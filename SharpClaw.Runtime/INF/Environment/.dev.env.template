{
  // SharpClaw Core development overrides.
  //
  // This file is loaded only when ASPNETCORE_ENVIRONMENT is Development.
  // It overrides Environment/.env and is intended for local debugging.

  "Jwt": {
    "Issuer": "SharpClaw",
    "Audience": "SharpClaw",
    "AccessTokenLifetime": "00:30:00",
    "RefreshTokenLifetime": "30.00:00:00"
  },

  "Auth": {
    "DisableApiKeyCheck": "false",
    "DisableAccessTokenCheck": "false"
    //, "AnonymousUsername": "guest"
  },
  "Agent": {
    "DisableCustomProviderParameters": "false"
  },

  "Chat": {
    "DisableDefaultHeaders": "false",
    "DisableDefaultSystemPrompt": "false",
    "DisableHeaderTagExpansion": "false",
    "DisableModuleHeaderTags": "false",
    "CacheMaxMegabytes": "2048"
  },

  "AgentOrchestration": {
    "DisableAccessibleThreadsHeader": "false"
  },

  "Database": {
    "EnableDetailedErrors": "true",
    "EnableSensitiveDataLogging": "false"
  },

  "Logging": {
    // Development defaults emit debug-level application timing logs. Raw
    // Serilog file output goes to serilog.txt; session ILogger output goes
    // to log.txt, debug.txt, and exceptions.txt in the instance log folder.
    "Serilog": {
      "Enabled": "true",
      "ConsoleEnabled": "true",
      "FileEnabled": "true",
      "RequestLoggingEnabled": "true",
      "MinimumLevel": "Debug",
      "MicrosoftMinimumLevel": "Information",
      "AspNetCoreMinimumLevel": "Information",
      "EntityFrameworkCoreMinimumLevel": "Information",
      "UnoMinimumLevel": "Information"
    }
  },

  "Admin": {
    "Username": "admin",
    "Password": "123456",
    "ReconcilePermissions": "true"
  },

  "Local": {
    "GpuLayerCount": "-1",
    "ContextSize": "8192",
    "KeepLoaded": "true",
    "IdleCooldownMinutes": "5",
    "MaxCachedSessions": "2",
    "ModelsDirectory": "",
    "HuggingFaceToken": ""
  },

  "EnvEditor": {
    "AllowNonAdmin": "false"
  },

  "UniqueNames": {
    "Agents": "true",
    "Channels": "true",
    "Providers": "true",
    "Models": "true",
    "Roles": "true",
    "Contexts": "true"
  },

  // External modules can come from a directory containing module.json or from
  // a NuGet package that carries the complete module payload. Package entries
  // use PackageId and Version, with optional Source and ModulePath.
  //"ExternalModules": [
  //  { "Path": "C:\\modules\\Custom.Module\\bin\\Debug\\net10.0", "Enabled": true },
  //  { "PackageId": "SharpClaw.Modules.Custom", "Version": "1.0.0", "Enabled": true }
  //],

  "Modules": {
    "CrashOnExternalModuleLoadFailure": "true",
    "EventDispatchTimeoutSeconds": "5",
    "HealthCheckIntervalSeconds": "60",
    "HealthCheckFailureThreshold": "3",
    "HealthCheckTimeoutSeconds": "10",
    "MaxEnvelopeSizeBytes": "1048576",
    "UnloadVerifyMaxAttempts": "10",
    "UnloadVerifyDelayMs": "100",
    "sharpclaw_agent_orchestration": "true",
    "sharpclaw_editor_common": "true",
    "sharpclaw_metrics": "true",
    "sharpclaw_module_dev": "true",
    "sharpclaw_providers_anthropic": "true",
    "sharpclaw_providers_google": "true",
    "sharpclaw_providers_llamasharp": "true",
    "sharpclaw_providers_ollama": "true",
    "sharpclaw_providers_openai_compat": "true",
    "sharpclaw_test_harness_out_of_process": "true",
    "sharpclaw_test_harness_in_process": "false",
    "sharpclaw_vs2026_editor": "true",
    "sharpclaw_vscode_editor": "true"
  }
}
